@@ -0,0 +1,94 @@
+import Foundation
+import Testing
+
+@testable import socktainer
+
+@Suite("Container logs tail")
+struct ContainerLogsTailTests {
+
+    // MARK: - tailLineCount
+
+    @Test("absent and \"all\" mean unlimited")
+    func unlimitedValues() {
+        #expect(ContainerLogsRoute.tailLineCount(nil) == nil)
+        #expect(ContainerLogsRoute.tailLineCount("all") == nil)
+    }
+
+    @Test("non-negative integers are line counts")
+    func validCounts() {
+        #expect(ContainerLogsRoute.tailLineCount("0") == 0)
+        #expect(ContainerLogsRoute.tailLineCount("5") == 5)
+        #expect(ContainerLogsRoute.tailLineCount("1000") == 1000)
+    }
+
+    @Test("unparsable and negative values are treated as unlimited")
+    func invalidValues() {
+        #expect(ContainerLogsRoute.tailLineCount("abc") == nil)
+        #expect(ContainerLogsRoute.tailLineCount("-3") == nil)
+        #expect(ContainerLogsRoute.tailLineCount("") == nil)
+        #expect(ContainerLogsRoute.tailLineCount("2.5") == nil)
+    }
+
+    // MARK: - tailStartOffset
+
+    private func withLogFile<T>(_ content: String, _ body: (FileHandle) throws -> T) throws -> T {
+        let url = FileManager.default.temporaryDirectory
+            .appendingPathComponent("tail-test-\(UUID().uuidString).log")
+        try Data(content.utf8).write(to: url)
+        defer { try? FileManager.default.removeItem(at: url) }
+        let handle = try FileHandle(forReadingFrom: url)
+        defer { try? handle.close() }
+        return try body(handle)
+    }
+
+    @Test("empty file returns 0")
+    func emptyFile() throws {
+        try withLogFile("") { fh in
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 1) == 0)
+        }
+    }
+
+    @Test("zero lines returns EOF so no history is emitted")
+    func zeroLines() throws {
+        try withLogFile("a\nb\nc\n") { fh in
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 0) == 6)
+        }
+    }
+
+    @Test("last N lines of a newline-terminated file")
+    func newlineTerminated() throws {
+        // "a\nb\nc\n" — offsets: a=0, b=2, c=4
+        try withLogFile("a\nb\nc\n") { fh in
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 1) == 4)
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 2) == 2)
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 3) == 0)
+        }
+    }
+
+    @Test("a trailing partial line with no newline counts as a line")
+    func unterminatedFinalLine() throws {
+        // "a\nb\nc" — c has no trailing newline but is still the last line
+        try withLogFile("a\nb\nc") { fh in
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 1) == 4)
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 2) == 2)
+        }
+    }
+
+    @Test("requesting more lines than exist returns the whole file")
+    func moreThanAvailable() throws {
+        try withLogFile("a\nb\nc\n") { fh in
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 99) == 0)
+        }
+    }
+
+    @Test("lines longer than the scan chunk size are handled")
+    func longLinesAcrossChunks() throws {
+        // A 5000-byte line forces the backward scan across chunk boundaries.
+        let long = String(repeating: "x", count: 5000)
+        let content = long + "\nend\n"
+        try withLogFile(content) { fh in
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 1) == 5001)
+            #expect(ContainerLogsRoute.tailStartOffset(fileHandle: fh, lines: 2) == 0)
+        }
+    }
+}
