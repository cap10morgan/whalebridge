+        let snapshot = try makeContainerSnapshot(
+            nativeId: "web", ip: "192.168.65.2", network: "bridge", labels: [:], status: .stopped, startedDate: nil)
+        let message = MissingContainerRuntimeState.message(for: snapshot, reference: "web")
+        #expect(message.contains("docker start web"))
+        #expect(message.contains("hasn't started"))
+        #expect(!message.contains("crashed"))
+        #expect(!message.contains("docker rm"))
+    }
+
+    @Test("a container that started and then lost its state gets docker rm -f guidance")
+    func startedThenLost() throws {
+        let snapshot = try makeContainerSnapshot(
+            nativeId: "web", ip: "192.168.65.2", network: "bridge", labels: [:], status: .stopped, startedDate: Date())
+        let message = MissingContainerRuntimeState.message(for: snapshot, reference: "web")
+        #expect(message.contains("docker rm -f web"))
+        #expect(message.contains("crashed abnormally"))
+        #expect(!message.contains("docker start"))
+    }
+
+    @Test("the reference passed in is what's embedded, not the snapshot's own id")
+    func referenceIsCallerSupplied() throws {
+        // Callers pass the URL's reference (name or short id), which is what
+        // a user would actually type back — not necessarily container.id.
+        let snapshot = try makeContainerSnapshot(
+            nativeId: "abcdef0123456789", ip: "192.168.65.2", network: "bridge", labels: [:], status: .stopped, startedDate: Date())
+        let message = MissingContainerRuntimeState.message(for: snapshot, reference: "buildx_buildkit_whalebridge")
+        #expect(message.contains("docker rm -f buildx_buildkit_whalebridge"))
+    }
+}
