diff --git a/Sources/socktainer/Utilities/MissingContainerRuntimeState.swift b/Sources/socktainer/Utilities/MissingContainerRuntimeState.swift
new file mode 100644
index 0000000..5cd3916
--- /dev/null
+++ b/Sources/socktainer/Utilities/MissingContainerRuntimeState.swift
@@ -0,0 +1,29 @@
+import ContainerResource
+
+/// A container whose on-disk runtime files (rootfs, logs) are missing can be
+/// in one of two very different situations:
+///
+/// - It may simply never have been started. Apple Container only
+///   materializes a container's filesystem at start, not at create, so a
+///   created-but-never-started container legitimately has no rootfs yet —
+///   this is expected, not an error. (buildx's docker-container driver hits
+///   this: it seeds files into a builder container via PUT .../archive
+///   before ever starting it.)
+/// - It may have started and then exited abnormally (e.g. an OOM kill),
+///   leaving its bundle incomplete. That really does mean the container
+///   needs to be removed and recreated.
+///
+/// `startedDate` tells the two apart.
+enum MissingContainerRuntimeState {
+    static func message(for container: ContainerSnapshot, reference: String) -> String {
+        if container.startedDate == nil {
+            return
+                "container hasn't started yet — Apple Container only creates its filesystem once a"
+                + " container starts, so this isn't available until then. Start it with"
+                + " `docker start \(reference)` and try again."
+        }
+        return
+            "container's runtime state is missing or corrupted (it may have crashed abnormally)"
+            + " — remove it with `docker rm -f \(reference)` and try again"
+    }
+}
diff --git a/Sources/socktainer/Utilities/PendingContainerBootstrap.swift b/Sources/socktainer/Utilities/PendingContainerBootstrap.swift
new file mode 100644
index 0000000..308e227
--- /dev/null
+++ b/Sources/socktainer/Utilities/PendingContainerBootstrap.swift
@@ -0,0 +1,27 @@
+import ContainerAPIClient
+
+/// EXPERIMENTAL: holds a container that's been bootstrapped (VM booted, rootfs
+/// materialized) on demand by an archive PUT/GET against a container that
+/// hasn't been started yet — buildx's docker-container driver seeds files
+/// into its builder container this way before ever calling /start.
+///
+/// `bootstrap()` boots the VM without running the container's init process;
+/// `process.start()` is the separate step that actually launches it. Storing
+/// the bootstrapped-but-not-started process here lets the real `/start`
+/// request (whenever the client gets around to it) reuse this exact process
+/// instead of bootstrapping a second time — Apple Container errors if you
+/// bootstrap an already-booted container, and calling .start() is what
+/// actually needs to happen at the right moment.
+actor PendingContainerBootstrap {
+    static let shared = PendingContainerBootstrap()
+
+    private var pending: [String: ClientProcess] = [:]
+
+    func store(id: String, process: ClientProcess) {
+        pending[id] = process
+    }
+
+    func take(id: String) -> ClientProcess? {
+        pending.removeValue(forKey: id)
+    }
+}
diff --git a/Sources/socktainer/Utilities/StartupHousekeeping.swift b/Sources/socktainer/Utilities/StartupHousekeeping.swift
new file mode 100644
index 0000000..9ca93dd
--- /dev/null
+++ b/Sources/socktainer/Utilities/StartupHousekeeping.swift
@@ -0,0 +1,43 @@
+import Foundation
+
+/// Runs best-effort startup work under a deadline that the work itself cannot
+/// extend or ignore.
+///
+/// Startup housekeeping (DNS-sidecar adoption, orphaned-network reaping) calls
+/// into Apple Container over XPC, and those calls can hang forever when the
+/// runtime is wedged (apple/container#1884: per-container/network operations
+/// hang indefinitely while reads keep working). Task cancellation can't
+/// interrupt an await stuck inside an XPC continuation, so a plain
+/// timeout-and-cancel race deadlocks with it. Instead the work runs in a
+/// detached task and the caller resumes on whichever finishes first — the work
+/// or the deadline. On timeout the stuck task is abandoned (it holds no
+/// resources the daemon needs) so startup can proceed and bind the API socket;
+/// the alternative is a daemon that never comes up at all.
+enum StartupHousekeeping {
+    /// Runs `work`, returning `true` if it finished within `timeout` and
+    /// `false` if it was abandoned at the deadline.
+    static func runBounded(timeout: Duration, _ work: @escaping @Sendable () async -> Void) async -> Bool {
+        final class Once: @unchecked Sendable {
+            private let lock = NSLock()
+            private var resumed = false
+            func claim() -> Bool {
+                lock.lock()
+                defer { lock.unlock() }
+                guard !resumed else { return false }
+                resumed = true
+                return true
+            }
+        }
+        let once = Once()
+        return await withCheckedContinuation { continuation in
+            Task.detached {
+                await work()
+                if once.claim() { continuation.resume(returning: true) }
+            }
+            Task.detached {
+                try? await Task.sleep(for: timeout)
+                if once.claim() { continuation.resume(returning: false) }
+            }
+        }
+    }
+}
