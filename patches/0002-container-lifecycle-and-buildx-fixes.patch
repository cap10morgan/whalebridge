index 0000000..0c19f01
--- /dev/null
+++ b/Tests/socktainerTests/Utilities/PendingContainerBootstrapTests.swift
@@ -0,0 +1,49 @@
+import ContainerAPIClient
+import ContainerizationOS
+import Testing
+
+@testable import socktainer
+
+private struct FakeClientProcess: ClientProcess {
+    let id: String
+    func start() async throws {}
+    func resize(_ size: Terminal.Size) async throws {}
+    func kill(_ signal: Int32) async throws {}
+    func wait() async throws -> Int32 { 0 }
+}
+
+@Suite("PendingContainerBootstrap")
+struct PendingContainerBootstrapTests {
+
+    @Test("take returns nil when nothing was ever stored for that id")
+    func takeNothingStoredReturnsNil() async {
+        let registry = PendingContainerBootstrap()
+        #expect(await registry.take(id: "never-stored") == nil)
+    }
+
+    @Test("take returns what was stored for that id")
+    func takeReturnsStoredProcess() async {
+        let registry = PendingContainerBootstrap()
+        let process = FakeClientProcess(id: "web")
+        await registry.store(id: "web", process: process)
+        let taken = await registry.take(id: "web")
+        #expect(taken?.id == "web")
+    }
+
+    @Test("take consumes the entry — a second take for the same id returns nil")
+    func takeIsOneShot() async {
+        let registry = PendingContainerBootstrap()
+        await registry.store(id: "web", process: FakeClientProcess(id: "web"))
+        _ = await registry.take(id: "web")
+        #expect(await registry.take(id: "web") == nil)
+    }
+
+    @Test("entries for different container ids don't collide")
+    func perContainerIsolation() async {
+        let registry = PendingContainerBootstrap()
+        await registry.store(id: "web", process: FakeClientProcess(id: "web"))
+        await registry.store(id: "db", process: FakeClientProcess(id: "db"))
+        #expect(await registry.take(id: "web")?.id == "web")
+        #expect(await registry.take(id: "db")?.id == "db")
+    }
+}
