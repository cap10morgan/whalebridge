+/// buildx's docker-container driver seeds files into a container via archive
+/// PUT before ever starting it. Apple Container only materializes a
+/// container's rootfs at bootstrap, so a rootfsNotFound on a container
+/// that's never been started gets one on-demand bootstrap (VM boot only —
+/// the init process isn't launched yet) and a single retry. The real
+/// /start request later reuses this bootstrapped process instead of
+/// bootstrapping a second time — see PendingContainerBootstrap. Verified
+/// against a real buildx build end to end (bootstrap here + the Privileged
+/// capability fix together let a real BuildKit build complete and run).
+///
+/// Bootstrapping makes the container's VM live, holding rootfs.ext4 open as
+/// its block device — putArchive takes a completely different path for a
+/// running container (writes through the VM, not the raw file) specifically
+/// because a raw write after this point would be invisible to the guest. The
+/// retry must see that via a freshly-fetched snapshot, not the pre-bootstrap
+/// one the caller already had, which still reports .stopped.
+///
+/// If the on-demand bootstrap itself fails, that's swallowed in favor of
+/// re-throwing the original rootfsNotFound — the caller's existing "hasn't
+/// started yet, run docker start" guidance is still correct and actionable,
+/// which a raw bootstrap error (e.g. an XPC failure) would not be.
+private func withRootfsMaterialized<T>(
+    container: ContainerSnapshot,
+    containerClient: ClientContainerProtocol,
+    _ operation: (ContainerSnapshot) async throws -> T
+) async throws -> T {
+    do {
+        return try await operation(container)
+    } catch let error as ClientArchiveError {
+        guard case .rootfsNotFound = error, container.startedDate == nil else { throw error }
+        guard let process = try? await ContainerClient().bootstrap(id: container.id, stdio: [nil, nil, nil]),
+            let refreshed = try? await containerClient.getContainer(id: container.id)
+        else { throw error }
+        await PendingContainerBootstrap.shared.store(id: container.id, process: process)
+        return try await operation(refreshed)
+    }
+}
