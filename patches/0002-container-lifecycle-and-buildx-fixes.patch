@@ -0,0 +1,155 @@
+import ContainerAPIClient
+import ContainerResource
+import Foundation
+import Testing
+import Vapor
+import VaporTesting
+
+@testable import socktainer
+
+/// A missing rootfs means the container's on-disk runtime state is gone, for
+/// one of two very different reasons that need very different guidance — see
+/// MissingContainerRuntimeState. All three /archive verbs must translate
+/// either case into a 409 with actionable guidance instead of leaking the
+/// raw "rootfs not found" message.
+@Suite("ContainerArchiveRoute — missing rootfs")
+struct ContainerArchiveRouteTests {
+
+    @Test("GET /archive on a started-then-crashed container suggests docker rm -f")
+    func getMissingRootfsAfterCrash() async throws {
+        let archive = FakeArchiveClient(getResult: .failure(.rootfsNotFound(id: "web")))
+        let snapshot = try makeContainerSnapshot(
+            nativeId: "web", ip: "192.168.65.2", network: "bridge", labels: [:], status: .stopped, startedDate: Date())
+        try await withArchiveApp(snapshot: snapshot, archive: archive) { app in
+            try await app.testing().test(.GET, "/v1.51/containers/web/archive?path=/etc") { res async in
+                #expect(res.status == .conflict)
+                #expect(res.body.string.contains("docker rm -f"))
+            }
+        }
+    }
+
+    @Test("GET /archive on a never-started container suggests docker start, not docker rm")
+    func getMissingRootfsNeverStarted() async throws {
+        // buildx's docker-container driver hits exactly this: it PUTs seed
+        // files into a builder container's /etc before ever starting it —
+        // Apple Container only materializes the rootfs at start.
+        let archive = FakeArchiveClient(getResult: .failure(.rootfsNotFound(id: "web")))
+        let snapshot = try makeContainerSnapshot(
+            nativeId: "web", ip: "192.168.65.2", network: "bridge", labels: [:], status: .stopped, startedDate: nil)
+        try await withArchiveApp(snapshot: snapshot, archive: archive) { app in
+            try await app.testing().test(.GET, "/v1.51/containers/web/archive?path=/etc") { res async in
+                #expect(res.status == .conflict)
+                #expect(res.body.string.contains("docker start"))
+                #expect(!res.body.string.contains("docker rm"))
+            }
+        }
+    }
+
+    @Test("HEAD /archive returns 409 with actionable guidance")
+    func headMissingRootfs() async throws {
+        let archive = FakeArchiveClient(getResult: .failure(.rootfsNotFound(id: "web")))
+        let snapshot = try makeContainerSnapshot(
+            nativeId: "web", ip: "192.168.65.2", network: "bridge", labels: [:], status: .stopped, startedDate: Date())
+        try await withArchiveApp(snapshot: snapshot, archive: archive) { app in
+            try await app.testing().test(.HEAD, "/v1.51/containers/web/archive?path=/etc") { res async in
+                #expect(res.status == .conflict)
+            }
+        }
+    }
+
+    @Test("PUT /archive returns 409 with actionable guidance")
+    func putMissingRootfs() async throws {
+        let archive = FakeArchiveClient(putResult: .failure(.rootfsNotFound(id: "web")))
+        let snapshot = try makeContainerSnapshot(
+            nativeId: "web", ip: "192.168.65.2", network: "bridge", labels: [:], status: .stopped, startedDate: Date())
+        try await withArchiveApp(snapshot: snapshot, archive: archive) { app in
+            try await app.testing().test(
+                .PUT, "/v1.51/containers/web/archive?path=/etc",
+                beforeRequest: { req in
+                    req.body = ByteBuffer(string: "fake-tar-bytes")
+                }
+            ) { res async in
+                #expect(res.status == .conflict)
+                #expect(res.body.string.contains("docker rm -f"))
+            }
+        }
+    }
+}
+
+// MARK: - Helpers
+
+private func withArchiveApp(
+    snapshot: ContainerSnapshot?,
+    archive: FakeArchiveClient,
+    test: @escaping (Application) async throws -> Void
+) async throws {
+    let client: ClientContainerProtocol = snapshot.map { FixedArchiveSnapshotClientMock(snapshot: $0) } ?? EmptyArchiveClientMock()
+    try await withApp(configure: { _ in }) { app in
+        let regexRouter = app.regexRouter(with: app.logger)
+        app.setRegexRouter(regexRouter)
+        regexRouter.installMiddleware(on: app)
+        try app.register(collection: ContainerArchiveRoute(containerClient: client, archiveClient: archive))
+        try await test(app)
+    }
+}
+
+private actor FakeArchiveClient: ClientArchiveProtocol {
+    private let getResult: Result<(tarData: Data, stat: PathStat), ClientArchiveError>
+    private let putResult: Result<Void, ClientArchiveError>
+
+    init(
+        getResult: Result<(tarData: Data, stat: PathStat), ClientArchiveError> = .failure(.operationFailed(message: "not under test")),
+        putResult: Result<Void, ClientArchiveError> = .failure(.operationFailed(message: "not under test"))
+    ) {
+        self.getResult = getResult
+        self.putResult = putResult
+    }
+
+    nonisolated func getRootfsPath(containerId: String) -> URL {
+        URL(fileURLWithPath: "/nonexistent/rootfs.ext4")
+    }
+
+    func getArchive(containerId: String, path: String) async throws -> (tarData: Data, stat: PathStat) {
+        try getResult.get()
+    }
+
+    func putArchive(container: ContainerSnapshot, path: String, tarPath: URL, noOverwriteDirNonDir: Bool) async throws {
+        try putResult.get()
+    }
+
+    func exportRootfs(containerId: String) async throws -> URL {
+        throw ClientArchiveError.operationFailed(message: "not under test")
+    }
+}
+
+private struct FixedArchiveSnapshotClientMock: ClientContainerProtocol {
+    let snapshot: ContainerSnapshot
+
+    func list(showAll: Bool, filters: [String: [String]]) async throws -> [ContainerSnapshot] { [snapshot] }
+    func getContainer(id: String) async throws -> ContainerSnapshot? { snapshot }
+    func enforceContainerRunning(container: ContainerSnapshot) throws {}
+    func start(id: String, detachKeys: String?) async throws {}
+    func stop(id: String, signal: String?, timeout: Int?) async throws {}
+    func restart(id: String, signal: String?, timeout: Int?) async throws {}
+    func kill(id: String, signal: String?) async throws {}
+    func delete(id: String) async throws {}
+    func wait(id: String, condition: ContainerWaitCondition) async throws -> RESTContainerWait {
+        RESTContainerWait(statusCode: 0)
+    }
+    func prune(filters: [String: [String]]) async throws -> (deletedContainers: [String], spaceReclaimed: Int64) { ([], 0) }
+}
+
+private struct EmptyArchiveClientMock: ClientContainerProtocol {
+    func list(showAll: Bool, filters: [String: [String]]) async throws -> [ContainerSnapshot] { [] }
+    func getContainer(id: String) async throws -> ContainerSnapshot? { nil }
+    func enforceContainerRunning(container: ContainerSnapshot) throws {}
+    func start(id: String, detachKeys: String?) async throws {}
+    func stop(id: String, signal: String?, timeout: Int?) async throws {}
+    func restart(id: String, signal: String?, timeout: Int?) async throws {}
+    func kill(id: String, signal: String?) async throws {}
+    func delete(id: String) async throws {}
+    func wait(id: String, condition: ContainerWaitCondition) async throws -> RESTContainerWait {
+        RESTContainerWait(statusCode: 0)
+    }
+    func prune(filters: [String: [String]]) async throws -> (deletedContainers: [String], spaceReclaimed: Int64) { ([], 0) }
+}
