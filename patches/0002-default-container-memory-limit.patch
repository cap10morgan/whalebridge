+    // Docker's 'no limit' sentinel (Memory=0, or the field absent) has no
+    // equivalent in Apple Container: VMs require a fixed RAM amount. Apple
+    // Container's own 1 GiB default is too little for real workloads, so we
+    // default to a percentage of host RAM instead — computed the same way
+    // the production code does, since the actual value is host-dependent.
+    // Pass an explicit (possibly empty) environment so these tests don't
+    // depend on — or race against — the real process environment.
+    private func defaultBytes(percent: Double = 75) -> UInt64 {
+        UInt64((Double(ProcessInfo.processInfo.physicalMemory) * percent / 100).rounded(.down))
