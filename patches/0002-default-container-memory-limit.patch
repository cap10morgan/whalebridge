@@ -902,9 +902,27 @@ func convertPortBindings(from portBindings: [String: [PortBinding]]) throws -> [
 }
 
 // Maps Docker HostConfig.Memory (bytes, 0 = no limit) to Apple Container memoryInBytes.
-// Returns nil when the value is absent, zero, or negative so the Apple Container
-// default (1 GiB) is preserved.
-func resolveMemoryInBytes(_ memory: Int?) -> UInt64? {
-    guard let memory, memory > 0 else { return nil }
-    return UInt64(memory)
+// When the value is absent, zero, or negative, Apple Container's own default
+// (1 GiB) is too little for real workloads — e.g. a Node/vite build can OOM
+// well under that — so we default instead to a percentage of host RAM,
+// leaving room for the host OS and other containers.
+func resolveMemoryInBytes(
+    _ memory: Int?,
+    environment: [String: String] = ProcessInfo.processInfo.environment
+) -> UInt64? {
+    if let memory, memory > 0 {
+        return UInt64(memory)
+    }
+    let hostMemory = ProcessInfo.processInfo.physicalMemory
+    guard hostMemory > 0 else { return nil }
+    return UInt64((Double(hostMemory) * defaultMemoryPercent(environment: environment) / 100).rounded(.down))
+}
+
+// Whalebridge (or any embedder) can override the default via this variable;
+// an absent, non-numeric, or out-of-range value falls back to 75%.
+func defaultMemoryPercent(environment: [String: String]) -> Double {
+    guard let raw = environment["SOCKTAINER_DEFAULT_MEMORY_PERCENT"],
+        let value = Double(raw), value > 0, value <= 100
+    else { return 75 }
+    return value
 }
