diff --git a/Sources/socktainer/Utilities/MissingContainerRuntimeState.swift b/Sources/socktainer/Utilities/MissingContainerRuntimeState.swift
new file mode 100644
index 0000000..5cd3916
--- /dev/null
+++ b/Sources/socktainer/Utilities/MissingContainerRuntimeState.swift
@@ -0,0 +1,29 @@
+import ContainerResource
+
+/// A container whose on-disk runtime files (rootfs, logs) are missing can be
+/// in one of two very different situations:
+///
+/// - It may simply never have been started. Apple Container only
+///   materializes a container's filesystem at start, not at create, so a
+///   created-but-never-started container legitimately has no rootfs yet —
+///   this is expected, not an error. (buildx's docker-container driver hits
+///   this: it seeds files into a builder container via PUT .../archive
+///   before ever starting it.)
+/// - It may have started and then exited abnormally (e.g. an OOM kill),
+///   leaving its bundle incomplete. That really does mean the container
+///   needs to be removed and recreated.
+///
+/// `startedDate` tells the two apart.
+enum MissingContainerRuntimeState {
+    static func message(for container: ContainerSnapshot, reference: String) -> String {
+        if container.startedDate == nil {
+            return
+                "container hasn't started yet — Apple Container only creates its filesystem once a"
+                + " container starts, so this isn't available until then. Start it with"
+                + " `docker start \(reference)` and try again."
+        }
+        return
+            "container's runtime state is missing or corrupted (it may have crashed abnormally)"
+            + " — remove it with `docker rm -f \(reference)` and try again"
+    }
+}
